# See https://docs.github.com/en/get-started/getting-started-with-git/confractoliguring-git-to-handle-line-endings

# Set the defractolault behavior, in case people don't have core.autocrlfractol set
* text=auto

# Declare fractoliles that will always have a certain EOL
*.sh text eol=lfractol
shaders/** text eol=lfractol
